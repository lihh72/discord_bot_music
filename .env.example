# Discord Bot Token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Directory to store downloaded music files
DOWNLOAD_DIR=./downloads

# Log file path
LOG_FILE=./mpaibot.log

# Idle timeout in seconds (disconnect from voice after this many seconds of no playback)
IDLE_TIMEOUT=300

# Path to cookies file for yt-dlp (Netscape/Mozilla format, exported from browser)
# Use browser extension like "Get cookies.txt LOCALLY" to export from YouTube
# Leave empty to not use cookies
YTDLP_COOKIES_FILE=
